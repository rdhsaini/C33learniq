{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "learniq-frontend",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "8080"],
      "port": 8080,
      "autoPort": false,
      "cwd": "frontend"
    },
    {
      "name": "learniq-backend",
      "runtimeExecutable": "uvicorn",
      "runtimeArgs": ["main:app", "--reload", "--port", "8000"],
      "port": 8000,
      "autoPort": false,
      "cwd": "backend"
    }
  ]
}
